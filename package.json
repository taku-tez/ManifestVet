{
  "name": "manifestvet",
  "version": "1.0.0",
  "description": "Kubernetes manifest security linter",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "bin": {
    "manifestvet": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "oss:scan": "ts-node --project tsconfig.scripts.json oss/scan.ts",
    "oss:analyze": "ts-node --project tsconfig.scripts.json oss/analyze.ts",
    "oss:scan:compare": "ts-node --project tsconfig.scripts.json oss/scan.ts && ts-node --project tsconfig.scripts.json oss/analyze.ts --compare",
    "oss:report": "ts-node --project tsconfig.scripts.json oss/analyze.ts"
  },
  "keywords": [
    "kubernetes",
    "security",
    "linter",
    "k8s",
    "manifest"
  ],
  "license": "MIT",
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
