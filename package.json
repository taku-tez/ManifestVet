{
  "name": "manifestvet",
  "version": "0.1.0",
  "description": "Kubernetes manifest security linter",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "bin": {
    "manifestvet": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
